{
  // ─────────────────────────────────────────────────────────────┤ header ├───

  "name": "main",
  "layer": "top",
  // "output": ["eDP-1", "DP-9"],
  "position": "top",
  "mode": "dock",
  "reload_style_on_change": true,
  "gtk-layer-shell": true,

  // ──────────────────────────────────────────────────────────┤ positions ├───

  "modules-left": [
    "custom/paddc",
    "custom/distro",        // distro icon
    "custom/paddc",
    "sway/workspaces",  // workspaces
    "custom/paddw",
    "sway/window",       // window title
    "custom/paddc",
    "mpris"                // media info
  ],

  "modules-center": [
    "clock#date",           // date
    "custom/paddc",
    "tray",
    "custom/paddc",
    "clock#time"           // time
  ],

  "modules-right": [
    "bluetooth",            // bluetooth
    "custom/paddw",
    "custom/wifi",          // wi-fi
    "custom/paddw",
    "idle_inhibitor",       // idle inhibitor
    "custom/paddw",
    "pulseaudio",           // output device
    "custom/paddw",
    "backlight",            // brightness
    "custom/paddw",
    "custom/temperature",   // temperature
    "custom/paddw",
    "memory",               // memory
    "custom/paddw",
    "cpu",                  // cpu
    "custom/paddw",
    "battery",              // battery
    "custom/paddw",
    "custom/power"          // power button
  ],

  // ─────────────────────────────────────────────────────────────┤ window ├───

  "sway/window": {
    "format": "{}",
    "tooltip": true,
    "min-length": 5,

    "rewrite": {
      // ────────────────────────────────────────────────────────── desktop ───
      "": 
        "<span foreground='#73ba25'> </span> Sway",

      // ───────────────────────────────────────────────────────── terminal ───

      "(.*)~(.*)": "  Terminal",
      "zsh": "  Terminal",
      "kitty": "  Terminal",
      "alacritty": "  Terminal",

      "tmux(.*)": 
        "<span foreground='#a8ff60'> </span> Tmux",

      "nvim": 
        "<span foreground='#a8ff60'> </span> Neovim",
      "nvim (.*)": 
        "<span foreground='#a8ff60'> </span> $1",

      // ──────────────────────────────────────────────────────────── media ───

      "(.*)Spotify": 
        "<span foreground='#a8ff60'> </span> Spotify",
      "(.*)Spotify Premium": 
        "<span foreground='#a8ff60'> </span> Spotify Premium",

      "OBS(.*)": 
        "<span foreground='#a8ff60'>󰻃 </span> OBS Studio",

      "VLC media player": 
        "<span foreground='#a8ff60'>󰕼 </span> VLC Media Player",
      "(.*) - VLC media player": 
        "<span foreground='#a8ff60'>󰕼 </span> $1",

      "qView": "󰋩  qView",

      "(.*).jpg": "󰋩  $1.jpg",
      "(.*).png": "󰋩  $1.png",
      "(.*).svg": "󰋩  $1.svg",

      // ──────────────────────────────────────────────────────── Communication ───

      "Telegram": 
        "<span foreground='#a8ff60'> </span> Telegram",

      // ──────────────────────────────────────────────────────── documents ───

      "ONLYOFFICE Desktop Editors": 
        "<span foreground='#a8ff60'> </span> OnlyOffice Desktop",

      "(.*).docx": 
        "<span foreground='#a8ff60'>󰈭 </span> $1.docx",
      "(.*).xlsx": 
        "<span foreground='#a8ff60'>󰈜 </span> $1.xlsx",
      "(.*).pptx": 
        "<span foreground='#a8ff60'>󰈨 </span> $1.pptx",
      "(.*).pdf": 
        "<span foreground='#a8ff60'> </span> $1.pdf",

      // ─────────────────────────────────────────────────────────── system ───

      "Authenticate": "  Authenticate"
    }
  },

  // ────────────────────────────────────────────────────────┤ temperature ├───

  "custom/temperature": {
    "exec": "$HOME/.config/waybar/scripts/cpu-temp.sh",
    "return-type": "json",
    "format": "{}",
    "interval": 5,
    "min-length": 8,
    "max-length": 8
  },

  // ─────────────────────────────────────────────────────────────┤ memory ├───

  "memory": {
    "states": {
      "warning": 75,
      "critical": 90
    },

    "format": "󰘚 {percentage}%",
    "format-critical": "󰀦 {percentage}%",
    "tooltip": true,
    "tooltip-format": "Memory Used: {used:0.1f} GB / {total:0.1f} GB",
    "interval": 5,
    "min-length": 7,
    "max-length": 7
  },

  // ────────────────────────────────────────────────────────────────┤ cpu ├───

  "cpu": {
    "format": "󰍛 {usage}%",
    "tooltip": true,
    "interval": 5,
    "min-length": 6,
    "max-length": 6
  },

  // ─────────────────────────────────────────────────────────────┤ distro ├───

  "custom/distro": {
    "format": " ",
    "on-click": "fuzzel",
    "tooltip": false
  },

  // ─────────────────────────────────────────────────────┤ idle inhibitor ├───

  "idle_inhibitor": {
    "format": "{icon}",

    "format-icons": {
      "activated": "󰈈 ",
      "deactivated": "󰈉 "
    },

    "tooltip-format-activated": "Presentation Mode",
    "tooltip-format-deactivated": "Idle Mode",
    "start-activated": false
  },

  // ───────────────────────────────────────────────────────────────┤ time ├───

  "clock#time": {
    "format": "  {:%H:%M} ",
    "tooltip": true,
    "tooltip-format": "Standard Time: {:%I:%M %p}",
    "min-length": 6,
    "max-length": 20
  },

  // ───────────────────────────────────────────────────────────────┤ date ├───

  "clock#date": {
    "format": " 󰸗 {:%m-%d} ",
    "tooltip-format": "<tt>{calendar}</tt>",

    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-click-right": "mode",

      "format": {
        "months": 
          "<span color='#b4ff39'><b>{}</b></span>",
        "weekdays": 
          "<span color='#e8f5e9'>{}</span>",
        "today": 
          "<span color='#e05f5f'><b>{}</b></span>"
      }
    },

    "actions": {
      "on-click": "mode",
      "on-click-right": "mode"
    },

    "min-length": 8,
    "max-length": 20
  },

  // ──────────────────────────────────────────────────────────────┤ wi-fi ├───

  "custom/wifi": {
    "exec": "$HOME/.config/waybar/scripts/wifi-status.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/sway/scripts/wifi-menu/wifi-menu.sh",
    "interval": 1
  },

  // ──────────────────────────────────────────────────────────┤ bluetooth ├───

  "bluetooth": {
    "format": "󰂰",
    "format-disabled": "󰂲",
    "format-connected": "󰂱",
    "format-connected-battery": "󰂱",

    "tooltip-format": 
      "{num_connections} connected",
    "tooltip-format-disabled": 
      "Bluetooth Disabled",
    "tooltip-format-connected": 
      "{device_enumerate}",
    "tooltip-format-enumerate-connected": 
      "{device_alias}",
    "tooltip-format-enumerate-connected-battery": 
      ":: {device_alias}: 󱊣 {device_battery_percentage}%",

    "on-click": "$HOME/.config/sway/scripts/bluethoot-menu/bluethoot-menu.sh",
    "interval": 1
  },

  // ─────────────────────────────────────────────────────────┤ media info ├───

  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "{status_icon} {title} - {artist}",

    "player-icons": {
      "default": "󰝚 ",
      "spotify": "<span foreground='#a8ff60'>󰓇 </span>"
    },
    "status-icons": {
      "paused": "<span color='#b4ff39'>\u200A\u200A󰏤\u2009\u2009</span>"
    },

    "tooltip-format": "Playing: {title} - {artist}",
    "tooltip-format-paused": "Paused: {title} - {artist}",
    "min-length": 5,
    "max-length": 25
  },

  // ──────────────────────────────────────────────────────┤ output device ├───

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 {volume}%",

    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"],
      "headphone": "󰋋",
      "headset": "󰋋"
    },

    "tooltip-format": "Device: {desc}",
    "on-click": "$HOME/.config/sway/scripts/volume-control.sh -o m",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "$HOME/.config/sway/scripts/volume-control.sh -o i",
    "on-scroll-down": "$HOME/.config/sway/scripts/volume-control.sh -o d",
    "min-length": 6,
    "max-length": 6
  },

  // ─────────────────────────────────────────────────────────┤ brightness ├───

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["", "", "", "", "", "", "", "", ""],
    "tooltip": false,
    "on-click": "$HOME/.config/sway/scripts/theme-switcher.sh",
    "on-scroll-up": "$HOME/.config/sway/scripts/brightness-control.sh -o i",
    "on-scroll-down": "$HOME/.config/sway/scripts/brightness-control.sh -o d",
    "min-length": 6
  },

  // ────────────────────────────────────────────────────────────┤ battery ├───

  "battery": {
    "states": {
      "warning": 20,
      "critical": 10
    },

    "format": "{icon} {capacity}%",
    "format-icons": ["󰂎", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "format-charging": " {capacity}%",

    "tooltip-format": "Discharging: {time}",
    "tooltip-format-charging": "Charging: {time}",
    "interval": 1,
    "min-length": 6,
    "max-length": 6,

    "on-click": "$HOME/.config/sway/scripts/powerprofiles-menu/powerprofiles-menu.sh"
  },

  // ───────────────────────────────────────────────────────┤ power button ├───

  "custom/power": {
    "format": " ",
    "tooltip": false,
    "on-click": "$HOME/.config/sway/scripts/power-menu/power-menu.sh"
  },

  // ────────────────────────────────────────────────────────────┤ padding ├───

  "custom/paddw": {
    "format": " ",
    "tooltip": false
  },

  "custom/paddc": {
    "format": " ",
    "tooltip": false
  }
}
